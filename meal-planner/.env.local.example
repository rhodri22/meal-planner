# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git — it's already in .gitignore.
#
# Get these from: supabase.com → your project → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Any random string — acts as the key that groups all your devices together.
# All devices that share this value will sync with each other.
# Generate one at: https://www.uuidgenerator.net
VITE_HOUSEHOLD_ID=your-random-uuid-here
